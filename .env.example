# asimu 环境变量模板 — 复制为 .env 后按需修改（.env 已加入 .gitignore）

# 配置文件路径（TOML）
# ASIMU_CONFIG=config/default.toml

# 求解器参数
# ASIMU_MAX_ITERATIONS=100
# ASIMU_TOLERANCE=1.0e-6

# 日志级别: error | warn | info | debug | trace
ASIMU_LOG_LEVEL=info

# tracing 过滤器（可选，覆盖 ASIMU_LOG_LEVEL）
# RUST_LOG=info,asimu=debug

# Chrome trace JSON（Perfetto）；等价于 --chrome-trace [PATH]
# ASIMU_CHROME_TRACE=profiling/trace.json
